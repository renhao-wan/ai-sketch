{
  "name": "smart-excalidraw-next",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "concurrently \"next dev --webpack\" \"wait-on http://localhost:3000 && bash -c 'unset ELECTRON_RUN_AS_NODE && electron .'\"",
    "electron:build": "ts-node --project scripts/tsconfig.json --transpile-only scripts/build.ts",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.ai-sketch.app",
    "productName": "AI Sketch",
    "directories": {
      "output": "dist",
      "buildResources": "electron/resources"
    }
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/dompurify": "^3.2.0",
    "dompurify": "^3.4.7",
    "lucide-react": "^1.16.0",
    "mermaid": "^11.15.0",
    "monaco-editor": "^0.55.1",
    "next": "16.0.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^8.2.2",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "eslint": "^9",
    "eslint-config-next": "16.0.1",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "wait-on": "^7.2.0"
  }
}
